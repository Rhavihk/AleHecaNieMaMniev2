# ============================================================
# TimeAway — Frontend Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── Firebase ─────────────────────────────────────────────────
# Wszystkie wartości z: Firebase Console → Project Settings → Your apps → Web app
REACT_APP_FIREBASE_API_KEY=AIzaSy...
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Discord OAuth ─────────────────────────────────────────────
# Z: https://discord.com/developers/applications → Twoja App → OAuth2
REACT_APP_DISCORD_CLIENT_ID=1234567890123456789

# ── Firebase Functions URL ────────────────────────────────────
# Format: https://us-central1-TWOJ_PROJECT_ID.cloudfunctions.net
# Znajdziesz po pierwszym deploy: firebase deploy --only functions
REACT_APP_FUNCTIONS_URL=https://us-central1-twoj-project-id.cloudfunctions.net
